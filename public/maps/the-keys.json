  "lyrics": [
    {
      "t": 19860,
      "text": "Everybody's leaving soon",
      "end": 21670
    },
    {
      "t": 21670,
      "text": "I can hear that rambling tune",
      "end": 24390
    },
    {
      "t": 24390,
      "text": "From the pool hall or any shopping mall",
      "end": 27080
    },
    {
      "t": 27080,
      "text": "We're going crazy as a loon",
      "end": 29720
    },
    {
      "t": 29720,
      "text": "Tell me where we're gonna go",
      "end": 31520
    },
    {
      "t": 31520,
      "text": "Where there's no sorrow, there's no snow",
      "end": 35280
    },
    {
      "t": 35280,
      "text": "Pack your suitcase light, we're gonna leave tonight",
      "end": 38880
    },
    {
      "t": 38880,
      "text": "'Cause I think I might just know",
      "end": 39700
    },
    {
      "t": 39700,
      "text": "Oh if I lose it",
      "end": 42400
    },
    {
      "t": 42400,
      "text": "I'm gonna move it",
      "end": 44260
    },
    {
      "t": 44260,
      "text": "Down to the Keys",
      "end": 46930
    },
    {
      "t": 46930,
      "text": "Maybe Idaho's not for me",
      "end": 48760
    },
    {
      "t": 48760,
      "text": "Don't need no jacket",
      "end": 51420
    },
    {
      "t": 51420,
      "text": "If you can't hack it",
      "end": 54150
    },
    {
      "t": 54150,
      "text": "You better come with me",
      "end": 56850
    },
    {
      "t": 56850,
      "text": "Down to the Keys",
      "end": 59580
    },
    {
      "t": 59580,
      "text": "There's a place down by the beach",
      "end": 62370
    },
    {
      "t": 62370,
      "text": "Where you can buy a peach",
      "end": 65060
    },
    {
      "t": 65060,
      "text": "Hear any Buffet tune if it's after noon",
      "end": 67770
    },
    {
      "t": 67770,
      "text": "And you promise not to preach",
      "end": 69560
    },
    {
      "t": 69560,
      "text": "There's a bar down by the pier",
      "end": 72220
    },
    {
      "t": 72220,
      "text": "Where I like to drink my beer",
      "end": 74910
    },
    {
      "t": 74910,
      "text": "And I can pay my tab with the gift of gab",
      "end": 77750
    },
    {
      "t": 77750,
      "text": "While the tourists shuffle through",
      "end": 79540
    },
    {
      "t": 79540,
      "text": "Oh if I lose it",
      "end": 82280
    },
    {
      "t": 82280,
      "text": "I'm gonna move it",
      "end": 84950
    },
    {
      "t": 84950,
      "text": "Down to the Keys",
      "end": 87690
    },
    {
      "t": 87690,
      "text": "Maybe Idaho's not for me",
      "end": 89420
    },
    {
      "t": 89420,
      "text": "Don't need no jacket",
      "end": 92180
    },
    {
      "t": 92180,
      "text": "If you can't hack it",
      "end": 94830
    },
    {
      "t": 94830,
      "text": "You better come with me",
      "end": 97580
    },
    {
      "t": 97580,
      "text": "Down to the Keys",
      "end": 140850
    },
    {
      "t": 140850,
      "text": "Mr. Gore don't lie, when the tide is high",
      "end": 143530
    },
    {
      "t": 143530,
      "text": "And we're swallowed by the sea",
      "end": 146370
    },
    {
      "t": 146370,
      "text": "Gonna float on down to the promised land",
      "end": 148070
    },
    {
      "t": 148070,
      "text": "Where the healthcare will be free"
    }
  ],
